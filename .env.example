# =============================================================================
# LangFens Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development
# IMPORTANT: Never commit .env.local or .env files to version control

# =============================================================================
# Backend API Configuration
# =============================================================================

# Base URL for the API gateway that routes to all backend microservices
# This is the main endpoint for all API calls (auth, exams, vocabulary, etc.)
# Example: http://localhost:8080 or https://api.langfens.com
NEXT_PUBLIC_GATEWAY_URL=

# =============================================================================
# Authentication
# =============================================================================

# Google OAuth Client ID for login functionality
# Get this from: https://console.cloud.google.com/apis/credentials
# Format: XXXXXX-XXXXXXXXXX.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Service-Specific Endpoints (Optional Overrides)
# =============================================================================
# These are automatically derived from NEXT_PUBLIC_GATEWAY_URL in api.customize.ts
# Only override if you need custom endpoints for specific services

# Auth Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-auth
# Exam Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-exams
# Attempt Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-attempts
# Vocabulary Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-vocabulary
# Speaking Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-speaking
# Writing Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-writing
# Chatbot Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-chatbot
# Dictionary Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-dictionary
# Gamification Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-gamification
# Analytics Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-analytics
# Notification Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-notification
# Study Plan Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-study-plan
# Course Service: ${NEXT_PUBLIC_GATEWAY_URL}/api-course

# =============================================================================
# Application Mode
# =============================================================================

# Set to 'development' or 'production'
NODE_ENV=development
